# Ortam Değişkenleri - Multi-Platform Chat Music Queue System

# Sunucu Ayarları
PORT=3000
NODE_ENV=development

# Kick API
# Kick API dokumentasyonu: https://developers.kick.com
KICK_API_KEY=your_kick_api_key_here
KICK_CHANNEL=your_kick_channel_name

# YouTube API
# YouTube API anahtarı al: https://console.cloud.google.com
YOUTUBE_API_KEY=your_youtube_api_key_here

# Spotify API
# Spotify Developer: https://developer.spotify.com
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Twitch API
# Twitch Developer: https://dev.twitch.tv
TWITCH_CLIENT_ID=your_twitch_client_id_here
TWITCH_OAUTH_TOKEN=your_twitch_oauth_token_here

# Discord Bot (Opsiyonel)
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CHANNEL_ID=your_discord_channel_id_here

# Veritabanı (Opsiyonel)
DATABASE_URL=sqlite:///database.db

# Logging
LOG_LEVEL=info
